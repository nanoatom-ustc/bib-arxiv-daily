@article{chang2020Efficiently,
  title = {Efficiently coupled microring circuit for on-chip cavity QED with trapped atoms},
  author = {Chang, Tzu-Han and Zhou, Xinchao and Zhu, Ming and Fields, Brian M. and Hung, Chen-Lung},
  year = 2020,
  month = oct,
  journal = {Appl. Phys. Lett.},
  volume = {117},
  number = {17},
  pages = {174001},
  doi = {10.1063/5.0023464},
  abstract = {We present a complete fabrication study of an efficiently coupled microring optical circuit tailored for cavity quantum electrodynamics with trapped atoms. The microring structures are fabricated on a transparent membrane with high in-vacuum fiber edge-coupling efficiency in a broad frequency band. In addition, a bus waveguide pulley coupler realizes critical coupling to the microrings at both of the cesium D-line frequencies, while high coupling efficiency is achieved at the cesium ``magic'' wavelengths for creating a lattice of two-color evanescent field traps above a microring. The presented platform holds promise for realizing a robust atom-nanophotonics hybrid quantum device.}
}

@article{chang2022Realization,
  title = {Realization of efficient 3D tapered waveguide-to-fiber couplers on a nanophotonic circuit},
  author = {Chang, Tzu-Han and Zhou, Xinchao and Tamura, Hikaru and Hung, Chen-Lung},
  year = 2022,
  month = aug,
  journal = {Opt. Express},
  volume = {30},
  number = {18},
  pages = {31643},
  doi = {10.1364/OE.468738},
  abstract = {We report the realization of efficiently coupled 3D tapered waveguide-to-fiber couplers (TWCs) based on standard lithography techniques. The 3D TWC design is capable of achieving highly efficient flat-cleaved fiber to silicon nitride photonic waveguide coupling, with T {$\approx$} 95 \% polarization-insensitive coupling efficiency, wide bandwidth, and good misalignment tolerance. Our fabricated 3D TWCs on a functional nanophotonic circuit achieve T {$\approx$} 85\% coupling efficiency. Beyond applications in high-efficiency photon coupling, the demonstrated 3D lithography technique provides a complementary approach for mode field shaping and effective refractive index engineering, potentially useful for general applications in integrated photonic circuits.}
}

