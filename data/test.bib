@article{thompson2013Coherence,
  title = {Coherence and Raman sideband cooling of a single atom in an optical tweezer},
  author = {Thompson, J. D. and Tiecke, T. G. and Zibrov, A. S. and Vuleti{\'c}, V. and Lukin, M. D.},
  year = 2013,
  month = mar,
  journal = {Phys. Rev. Lett.},
  volume = {110},
  number = {13},
  eprint = {1209.3028},
  primaryclass = {physics, physics:quant-ph},
  pages = {133001},
  doi = {10.1103/PhysRevLett.110.133001},
  abstract = {We investigate quantum control of a single atom in an optical tweezer trap created by a tightly focused optical beam. We show that longitudinal polarization components in the dipole trap arising from the breakdown of the paraxial approximation give rise to significant internal-state decoherence. We show that this effect can be mitigated by appropriate choice of magnetic bias field, enabling Raman sideband cooling of a single atom close to its three-dimensional ground state in an optical trap with a beam waist as small as \$w=900\$ nm. We achieve vibrational occupation numbers of \$\textbackslash bar\textbraceleft n\textbraceright\_r = 0.01\$ and \$\textbackslash bar\textbraceleft n\textbraceright\_a = 8\$ in the radial and axial directions of the trap, corresponding to an rms size of the atomic wavepacket of 24 nm and 270 nm, respectively. This represents a promising starting point for future hybrid quantum systems where atoms are placed in close proximity to surfaces.},
  archiveprefix = {arXiv}
}

@article{thompson2013Coupling,
  title = {Coupling a Single Trapped Atom to a Nanoscale Optical Cavity},
  author = {Thompson, J. D. and Tiecke, T. G. and {de Leon}, N. P. and Feist, J. and Akimov, A. V. and Gullans, M. and Zibrov, A. S. and Vuleti{\'c}, V. and Lukin, M. D.},
  year = 2013,
  month = jun,
  journal = {Science},
  volume = {340},
  number = {6137},
  pages = {1202--1205},
  publisher = {American Association for the Advancement of Science},
  doi = {10.1126/science.1237125},
  abstract = {Hybrid quantum devices, in which dissimilar quantum systems are combined in order to attain qualities not available with either system alone, may enable far-reaching control in quantum measurement, sensing, and information processing. A paradigmatic example is trapped ultracold atoms, which offer excellent quantum coherent properties, coupled to nanoscale solid-state systems, which allow for strong interactions. We demonstrate a deterministic interface between a single trapped rubidium atom and a nanoscale photonic crystal cavity. Precise control over the atom's position allows us to probe the cavity near-field with a resolution below the diffraction limit and to observe large atom-photon coupling. This approach may enable the realization of integrated, strongly coupled quantum nano-optical circuits.}
}

