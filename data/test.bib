@article{zhang2011GaNa,
  title = {GaN directional couplers for integrated quantum photonics},
  author = {Zhang, Yanfeng and McKnight, Loyd and Engin, Erman and Watson, Ian M. and Cryan, Martin J. and Gu, Erdan and Thompson, Mark G. and Calvez, Stephane and O'Brien, Jeremy L. and Dawson, Martin D.},
  year = 2011,
